----------- PATCH ---------------

curl -L -X PATCH 'http://192.168.100.233:9990/edge/admin/plugin_configs/5001' -H 'X-API-KEY: f9357106bff442f89d4de7169c37c61e' -H 'Content-Type: application/json' --data-raw '{
    "desc": "test1",
    "plugins": {
        "auth_key": {
            "disable": true
        }
    }
}'

{
    "action": "compareAndSwap",
    "succeeded": true,
    "node": {
        "key": "/edge/plugin_configs/5001",
        "value": {
            "desc": "test1",
            "plugins": {
                "auth_key": {
                    "query": "apikey",
                    "disable": true,
                    "header": "apikey",
                    "hide_credentials": false
                }
            },
            "id": "5001",
            "create_time": 1675916946,
            "update_time": 1675917127
        }
    },
    "header": {
        "revision": 1
    }
}

