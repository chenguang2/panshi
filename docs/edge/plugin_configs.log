----------- PUT ---------------

curl -L -X PUT 'http://192.168.100.233:9990/edge/admin/plugin_configs/5001' -H 'X-API-KEY: f9357106bff442f89d4de7169c37c61e' -H 'Content-Type: application/json' --data-raw '{
    "desc": "test",
    "plugins": {
        "auth_key": {}
    }
}'

{
    "action": "set",
    "node": {
        "key": "/edge/plugin_configs/5001",
        "value": {
            "desc": "test",
            "plugins": {
                "auth_key": {
                    "hide_credentials": false,
                    "header": "apikey",
                    "query": "apikey"
                }
            },
            "update_time": 1675916946,
            "create_time": 1675916946,
            "id": "5001"
        }
    },
    "header": {}
}


