----------- POST ---------------

curl -L -X POST 'http://127.0.0.1:9990/edge/admin/upstreams' -H 'X-API-KEY: f9357106bff442f89d4de7169c37c61e' -H 'Content-Type: application/json' --data-raw '{
    "type":"roundrobin",
    "nodes":{
        "127.0.0.1:1980": 1
    }
}'

{
    "action": "create",
    "node": {
        "key": "/edge/upstreams/00be4add130b4fb08f17c7011666ec43",
        "value": {
            "type": "roundrobin",
            "id": "00be4add130b4fb08f17c7011666ec43",
            "update_time": 1673596019,
            "hash_on": "vars",
            "pass_host": "pass",
            "scheme": "http",
            "nodes": {
                "127.0.0.1:1980": 1
            },
            "create_time": 1673596019
        }
    },
    "header": {}
}


