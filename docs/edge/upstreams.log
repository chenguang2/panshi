    "type":"roundrobin",
    "nodes":{
        "127.0.0.1:1980": 1
    }
}'

{
    "action": "set",
    "node": {
        "key": "/edge/upstreams/1001",
        "value": {
            "type": "roundrobin",
            "update_time": 1673595867,
            "pass_host": "pass",
            "hash_on": "vars",
            "id": "1001",
            "scheme": "http",
            "nodes": {
                "127.0.0.1:1980": 1
            },
            "create_time": 1673595867
        }
    },
    "header": {}
}


