----------- PATCH ---------------

curl -L -X PATCH 'http://127.0.0.1:9990/edge/admin/upstreams/1001' -H 'X-API-KEY: f9357106bff442f89d4de7169c37c61e' -H 'Content-Type: application/json' --data-raw '{
    "nodes": {
        "127.0.0.1:1981": 1
    }
}'

{
    "action": "compareAndSwap",
    "succeeded": true,
    "node": {
        "key": "/edge/upstreams/1001",
        "value": {
            "type": "roundrobin",
            "pass_host": "pass",
            "scheme": "http",
            "hash_on": "vars",
            "id": "1001",
            "update_time": 1673595926,
            "nodes": {
                "127.0.0.1:1981": 1,
                "127.0.0.1:1980": 1
            },
            "create_time": 1673595923
        }
    },
    "header": {
        "revision": 42
    }
}

