----------- PUT ---------------

curl -L -X PUT 'http://192.168.100.233:9990/edge/admin/consumers' -H 'X-API-KEY: f9357106bff442f89d4de7169c37c61e' -H 'Content-Type: application/json' --data-raw '{
    "username": "CAtest1",
    "plugins": {
        "auth_basic": {
            "password": "test",
            "disable": false,
            "username": "test1"
        }
    }
}'

