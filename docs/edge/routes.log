----------- POST ---------------

curl -L -X POST 'http://192.168.100.233:9990/edge/admin/routes' -H 'X-API-KEY: f9357106bff442f89d4de7169c37c61e' -H 'Content-Type: application/json' --data-raw '{
    "uri": "/hi",
    "upstream": {
        "nodes": {
            "127.0.0.1:8111": 1
        },
        "type": "roundrobin"
    }
}'

{
    "action": "create",
    "node": {
        "key": "/edge/routes/cbebbf084e0f4dc0b8c5249efb4796b7",
        "value": {
            "uri": "/hi",
            "create_time": 1673599966,
            "update_time": 1673599966,
            "id": "cbebbf084e0f4dc0b8c5249efb4796b7",
            "status": 1,
            "priority": 0,
            "upstream": {
                "type": "roundrobin",
                "hash_on": "vars",
                "pass_host": "pass",
                "scheme": "http",
                "nodes": {
                    "127.0.0.1:8111": 1
                }
            }
        }
    },
    "header": {}
}

